<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-text">{{ site.name }}</span>
      </a>

      <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger"></span>
      </button>

      <nav class="main-nav" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="/" class="{% if page.url == '/' %}active{% endif %}">Home</a></li>
          <li><a href="/about/" class="{% if '/about/' in page.url %}active{% endif %}">About</a></li>
          <li class="has-dropdown">
            <button class="dropdown-toggle" aria-expanded="false">Services<span class="arrow">▼</span></button>
            <ul class="dropdown-menu">
              <li><a href="/services/">All Services</a></li>
              <li><a href="/services/growth-strategy/">Growth Strategy</a></li>
              <li><a href="/services/operational-excellence/">Operational Excellence</a></li>
              <li><a href="/services/market-expansion/">Market Expansion</a></li>
              <li><a href="/services/digital-transformation/">Digital Transformation</a></li>
            </ul>
          </li>
          <li><a href="/case-studies/" class="{% if '/case-studies/' in page.url %}active{% endif %}">Case Studies</a></li>
          <li><a href="/insights/" class="{% if '/insights/' in page.url %}active{% endif %}">Insights</a></li>
          <li><a href="/contact/" class="{% if '/contact/' in page.url %}active{% endif %}">Contact</a></li>
        </ul>
        <a href="/contact/" class="btn btn-primary nav-cta">Schedule Strategic Session</a>
      </nav>
    </div>
  </div>
</header>
